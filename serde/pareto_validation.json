{
  "description": "Validation configs from Pareto front (top 3 rows)",
  "combinations": [
    {
      "name": "PARETO_ROW_2",
      "llvm": {
        "pass": "from_pareto",
        "switches": [
          "-disable-cgp-branch-opts",
          "-disable-early-ifcvt",
          "-disable-early-taildup",
          "-disable-layout-fsprofile-loader",
          "-disable-loop-level-heuristics",
          "-disable-promote-alloca-to-vector",
          "-disable-tail-calls"
        ],
        "parameters": {}
      },
      "mir": {
        "pass": "from_pareto",
        "switches": [
          "-CopyProp",
          "-DeadStoreElimination-final",
          "-ImpossiblePredicates",
          "-InstSimplify-before-inline",
          "-ReferencePropagation",
          "-ScalarReplacementOfAggregates",
          "-UnreachableEnumBranching"
        ],
        "parameters": {}
      }
    },
    {
      "name": "PARETO_ROW_3",
      "llvm": {
        "pass": "from_pareto",
        "switches": [
          "-disable-binop-extract-shuffle",
          "-disable-cgp-store-extract",
          "-disable-early-ifcvt",
          "-disable-lsr",
          "-disable-nofree-inference",
          "-disable-preheader-prot",
          "-disable-promote-alloca-to-vector"
        ],
        "parameters": {}
      },
      "mir": {
        "pass": "from_pareto",
        "switches": [
          "-GVN",
          "-ImpossiblePredicates",
          "-ScalarReplacementOfAggregates"
        ],
        "parameters": {}
      }
    },
    {
      "name": "PARETO_ROW_4",
      "llvm": {
        "pass": "from_pareto",
        "switches": [
          "-disable-2addr-hack",
          "-disable-adv-copy-opt",
          "-disable-binop-extract-shuffle",
          "-disable-block-placement",
          "-disable-cgp-select2branch",
          "-disable-loop-idiom-vectorize-all",
          "-disable-loop-level-heuristics"
        ],
        "parameters": {}
      },
      "mir": {
        "pass": "from_pareto",
        "switches": [
          "-CopyProp",
          "-DataflowConstProp",
          "-ImpossiblePredicates",
          "-ScalarReplacementOfAggregates",
          "-UnreachablePropagation"
        ],
        "parameters": {}
      }
    }
  ]
}
